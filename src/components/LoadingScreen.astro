---
// Premium boot screen. Progress + status are driven by GSAP in index.astro,
// which coordinates the fade-out with the hero entrance.
---

<div
  id="loader"
  class="bg-bg fixed inset-0 z-[100] flex flex-col items-center justify-center"
  role="status"
  aria-live="polite"
  aria-label="Loading ongki.pro"
>
  <!-- corner labels -->
  <span
    class="absolute top-6 left-6 font-mono text-[10px] tracking-[0.3em] text-white/25 uppercase"
  >
    System Boot
  </span>
  <span
    class="absolute right-6 bottom-6 font-mono text-[10px] tracking-[0.3em] text-white/25 uppercase"
  >
    ongki.pro // OS
  </span>

  <div class="flex w-[min(420px,82vw)] flex-col items-center gap-6">
    <!-- Core motif drawn by GSAP DrawSVG, synced to the boot counter (0→100%). -->
    <svg
      class="text-accent h-20 w-20"
      viewBox="0 0 100 100"
      fill="none"
      stroke="currentColor"
      stroke-width="1.25"
      aria-hidden="true"
    >
      <circle class="boot-draw" cx="50" cy="50" r="46" opacity="0.45"></circle>
      <ellipse class="boot-draw" cx="50" cy="50" rx="46" ry="16" opacity="0.7"></ellipse>
      <ellipse
        class="boot-draw"
        cx="50"
        cy="50"
        rx="46"
        ry="16"
        opacity="0.55"
        transform="rotate(60 50 50)"></ellipse>
      <ellipse
        class="boot-draw"
        cx="50"
        cy="50"
        rx="46"
        ry="16"
        opacity="0.55"
        transform="rotate(-60 50 50)"></ellipse>
      <circle class="boot-draw text-accent-bright" cx="50" cy="50" r="15" stroke-width="2"></circle>
    </svg>

    <div class="font-mono text-sm tracking-[0.4em] text-white/70 uppercase">
      ongki<span class="text-accent">.pro</span>
    </div>

    <div class="flex items-end gap-1">
      <span id="loader-percent" class="font-mono text-6xl font-light text-white tabular-nums">
        000
      </span>
      <span class="text-accent mb-2 font-mono text-xl">%</span>
    </div>

    <div class="h-px w-full overflow-hidden bg-white/10">
      <span
        id="loader-bar"
        class="from-accent to-accent-bright block h-full w-full origin-left scale-x-0 bg-gradient-to-r shadow-[0_0_10px_rgb(93_123_255_/_0.8)]"
      ></span>
    </div>

    <div id="loader-status" class="font-mono text-[11px] tracking-[0.3em] text-white/50 uppercase">
      Initializing Infrastructure
    </div>
  </div>
</div>

<!-- If JS is disabled, never trap the user behind the loader. -->
<noscript>
  <style>
    #loader {
      display: none !important;
    }
  </style>
</noscript>
